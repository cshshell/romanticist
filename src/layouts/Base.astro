---
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/syne/700.css';
import '@fontsource/syne/800.css';
import '../styles/global.scss';
import { SITE } from '../site.config';
import Header from '../components/Header.astro';
import Search from '../components/Search.astro';

interface Props {
  title: string;
  description?: string;
}

// se a pagina nao passar descricao, usa a padrao do site.config
const { title, description = SITE.description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="alternate" type="application/rss+xml" title={SITE.domain} href="/rss.xml" />
    <!-- marca js cedo, pro reveal so esconder conteudo quando tem js -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a href="#content" class="skip">skip to content</a>
    <Header />
    <slot />
    <Search />

    <script>
      // reveal sutil no scroll, estilo apple. respeita reduced-motion
      const els = document.querySelectorAll('[data-reveal]');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
