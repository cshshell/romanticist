---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { formatDate } from '../../utils/date';
import { SITE } from '../../site.config';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tags = new Set<string>();
  posts.forEach((p) => p.data.tags.forEach((t) => tags.add(t)));

  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Base title={`#${tag} — ${SITE.domain}`}>
  <main class="taglist" id="content">
    <a href="/tags" class="backlink">← tags</a>
    <h1 class="taglist__title">#{tag}</h1>
    <ul class="taglist__list">
      {
        posts.map((p) => (
          <li>
            <a href={`/posts/${p.id}`}>
              <span class="taglist__name">{p.data.title}</span>
              <time class="taglist__date" datetime={p.data.date.toISOString()}>
                {formatDate(p.data.date)}
              </time>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Base>
