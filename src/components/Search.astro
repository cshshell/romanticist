---
// modal de busca, abre com ctrl+k (ou cmd+k no mac).
// e o spotlight/command palette do site, substitui o terminal antigo
---

<div id="search-modal" class="search" hidden>
  <div class="search__backdrop" data-search-close></div>
  <div class="search__panel" role="dialog" aria-modal="true" aria-label="search">
    <input
      type="text"
      id="search-input"
      class="search__input"
      placeholder="search"
      autocomplete="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="search posts"
    />
    <ul id="search-results" class="search__results"></ul>
    <p id="search-empty" class="search__empty" hidden>no results</p>
  </div>
</div>

<script>
  import Fuse from 'fuse.js';

  type Item = {
    title: string;
    description: string;
    category: string;
    tags: string[];
    date: string;
    url: string;
  };

  const modal = document.getElementById('search-modal') as HTMLElement;
  const input = document.getElementById('search-input') as HTMLInputElement;
  const list = document.getElementById('search-results') as HTMLElement;
  const empty = document.getElementById('search-empty') as HTMLElement;

  let fuse: Fuse<Item> | null = null;
  let active = -1;

  // carrega o indice so uma vez, na primeira vez que abre
  async function ensureIndex() {
    if (fuse) return;
    const res = await fetch('/search.json');
    const items: Item[] = await res.json();
    fuse = new Fuse(items, {
      keys: ['title', 'tags', 'category', 'description'],
      threshold: 0.4,
      ignoreLocation: true,
    });
  }

  function open() {
    ensureIndex();
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    input.value = '';
    render([]);
    requestAnimationFrame(() => input.focus());
  }

  function close() {
    modal.hidden = true;
    document.body.style.overflow = '';
    active = -1;
  }

  function render(results: Item[]) {
    list.innerHTML = '';
    active = -1;
    empty.hidden = results.length > 0 || input.value.trim() === '';
    for (const r of results) {
      const li = document.createElement('li');
      li.className = 'search__result';
      const a = document.createElement('a');
      a.href = r.url;
      const title = document.createElement('span');
      title.className = 'search__rtitle';
      title.textContent = r.title;
      const meta = document.createElement('span');
      meta.className = 'search__rmeta';
      meta.textContent = `${r.category} · ${r.date}`;
      a.append(title, meta);
      li.append(a);
      list.append(li);
    }
  }

  function query(q: string) {
    if (!fuse || q.trim() === '') {
      render([]);
      return;
    }
    const results = fuse.search(q).slice(0, 8).map((x) => x.item);
    render(results);
  }

  function move(dir: number) {
    const links = list.querySelectorAll('a');
    if (links.length === 0) return;
    active = (active + dir + links.length) % links.length;
    links.forEach((el, i) => el.classList.toggle('is-active', i === active));
    links[active]?.scrollIntoView({ block: 'nearest' });
  }

  input.addEventListener('input', () => query(input.value));

  document.addEventListener('keydown', (e) => {
    const cmdk = (e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k';
    if (cmdk) {
      e.preventDefault();
      modal.hidden ? open() : close();
      return;
    }
    if (modal.hidden) return;
    if (e.key === 'Escape') {
      e.preventDefault();
      close();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      move(1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      move(-1);
    } else if (e.key === 'Enter') {
      const links = list.querySelectorAll('a');
      const target = active >= 0 ? links[active] : links[0];
      if (target) window.location.href = (target as HTMLAnchorElement).href;
    }
  });

  modal.querySelectorAll('[data-search-close]').forEach((el) =>
    el.addEventListener('click', close)
  );
</script>
